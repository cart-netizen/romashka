# =============================================================================
# deploy/.env.example — конфигурация прод-стека. Скопируйте в deploy/.env.
# install.sh генерирует пустые секреты автоматически. .env в git НЕ коммитится.
# ВАЖНО: НЕ ставьте inline-комментарии после '=' — в .env весь текст после
# знака равенства считается значением (иначе комментарий попадёт в секрет).
# =============================================================================

# --- Домены (install.sh перезапишет из SITE_DOMAIN/CMS_DOMAIN) ---
SITE_URL=https://paleron.ru
DIRECTUS_PUBLIC_URL=https://cms.paleron.ru

# --- Localhost-порты (shared-режим: сервер с другими сайтами) ---
# web/Directus слушают ТОЛЬКО 127.0.0.1; наружу проксирует хостовый nginx.
# install.sh ВСЕГДА проверяет занятость и сдвигает порт вверх, если занят.
WEB_PORT=8080
DIRECTUS_PORT=8055

# --- PostgreSQL ---
DB_DATABASE=directus
DB_USER=directus
# Пароль БД — генерируется install.sh, если пусто (openssl rand -hex 24)
DB_PASSWORD=

# --- Directus ---
# KEY/SECRET — генерируются install.sh, если пусто (openssl rand -hex 32)
DIRECTUS_KEY=
DIRECTUS_SECRET=
ADMIN_EMAIL=admin@paleron.ru
# Пароль администратора — генерируется install.sh, если пусто
ADMIN_PASSWORD=
# Статический токен сервисного пользователя (серверная запись лидов/подписок).
# Отдельный пользователь с минимальными правами, НЕ админ. См. DEPLOY_RUNBOOK §4.
DIRECTUS_ADMIN_TOKEN=

# --- MAX Bot API (вводит заказчик) ---
MAX_BOT_TOKEN=
MAX_ADMIN_CHAT_ID=
MAX_API_BASE=https://platform-api.max.ru
MAX_NOTIFY_TOKEN=
MAX_NOTIFY_SENDER=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_EMAIL_TO=

# --- Аналитика ---
NEXT_PUBLIC_YANDEX_METRICA_ID=
YANDEX_WEBMASTER_VERIFICATION=
