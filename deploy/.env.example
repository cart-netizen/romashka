# =============================================================================
# deploy/.env.example — конфигурация прод-стека. Скопируйте в deploy/.env.
# Все секреты — СГЕНЕРИРУЙТЕ заново. .env в git НЕ коммитится.
# =============================================================================

# --- Домены ---
SITE_URL=https://paleron.ru                 # основной сайт (web)
DIRECTUS_PUBLIC_URL=https://cms.paleron.ru   # Directus (поддомен)

# --- Localhost-порты (shared-режим: сервер с другими сайтами) ---
# Используются только docker-compose.shared.yml + install.sh.
# web/Directus слушают ТОЛЬКО 127.0.0.1 на этих портах, наружу их проксирует
# хостовый nginx. install.sh подберёт свободные автоматически, если пусто.
WEB_PORT=8080
DIRECTUS_PORT=8055

# --- PostgreSQL ---
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=                                   # надёжный пароль

# --- Directus ---
DIRECTUS_KEY=                                  # openssl rand -hex 32
DIRECTUS_SECRET=                               # openssl rand -hex 32
ADMIN_EMAIL=admin@paleron.ru
ADMIN_PASSWORD=                                # надёжный пароль
# Статический токен сервисного пользователя (для серверной записи лидов/подписок).
# Рекомендуется отдельный пользователь с минимальными правами, не админ.
DIRECTUS_ADMIN_TOKEN=

# --- MAX Bot API (вводит заказчик) ---
MAX_BOT_TOKEN=
MAX_ADMIN_CHAT_ID=
MAX_API_BASE=https://platform-api.max.ru
MAX_NOTIFY_TOKEN=
MAX_NOTIFY_SENDER=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_EMAIL_TO=

# --- Аналитика ---
NEXT_PUBLIC_YANDEX_METRICA_ID=
YANDEX_WEBMASTER_VERIFICATION=
