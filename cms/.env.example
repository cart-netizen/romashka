# =============================================================================
# cms/.env.example — конфигурация Docker Compose (Directus + Postgres).
# Скопируйте в cms/.env и задайте значения. cms/.env в git НЕ коммитится.
# Для локальной разработки значения ниже можно использовать как есть.
# Для прода — СГЕНЕРИРУЙТЕ новые секреты и надёжные пароли.
# =============================================================================

# --- PostgreSQL ---
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=change_me_dev_password

# --- Directus ---
# KEY/SECRET — случайные строки (напр. `openssl rand -hex 32`). Не использовать дефолты на проде.
DIRECTUS_KEY=replace_with_random_key
DIRECTUS_SECRET=replace_with_random_secret

# Учётка первого администратора (создаётся при первом старте)
ADMIN_EMAIL=admin@romashka.local
ADMIN_PASSWORD=change_me_admin_password

# Публичный URL Directus (локально — порт 8055)
PUBLIC_URL=http://localhost:8055
